# 复制为 .env 后填写，然后 docker compose up -d
# 不要将 .env 提交到版本控制

# --- 数据库密码（必填） ---
MYSQL_ROOT_PASSWORD=请替换MySQL根密码
MYSQL_PASSWORD=请替换MySQL用户密码
NEO4J_PASSWORD=请替换Neo4j密码

# --- 可选：覆盖默认值 ---
# MYSQL_DATABASE=suilli_mizi
# MYSQL_USER=suilli_mizi
# NEO4J_USER=neo4j
# MYSQL_PORT=3306
# WEB_PORT=80

# --- Flask 密钥 ---
SECRET_KEY=请替换为至少32位随机字符串

# --- LLM API Key（按需填写） ---
ARK_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
GRAPH_LLM_API_KEY=

# --- OCR ---
OCR_APP_ID=
OCR_API_KEY=
OCR_SECRET_KEY=

# --- 生产域名 ---
# FRONTEND_ORIGIN=https://你的域名
