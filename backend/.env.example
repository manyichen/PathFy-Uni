# 复制为 backend/.env 后填写真实值（勿提交 .env）

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace-with-a-random-secret
TOKEN_EXPIRES_HOURS=24

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=suilli_mizi

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Doubao(Ark) 岗位 AI 助手
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-mini-260215
AI_MAX_RETURN_JOBS=40
AI_CONTEXT_WINDOW=6
AI_LLM_TIMEOUT_SECONDS=90

FRONTEND_ORIGIN=http://localhost:4321

# 简历 OCR / 通义（按功能选用）
OCR_APP_ID=
OCR_API_KEY=
OCR_SECRET_KEY=
DASHSCOPE_API_KEY=

# 虚构画像列表（GET /api/profile/mocks），开发环境未写时默认开启；生产可显式 0 关闭
ENABLE_MOCK_PROFILE_API=

# 人岗匹配 POST /api/match/preview（Neo4j 粗排 + 可选 DeepSeek 精排）
MATCH_PREVIEW_MAX_SCAN=2000
MATCH_PREVIEW_MAX_SCAN_HARD=8000
MATCH_TOP_K_RETURN=30
MATCH_LLM_POOL_K=40
DEEPSEEK_API_KEY=
MATCH_DEEPSEEK_MODEL=deepseek-chat
MATCH_LLM_TIMEOUT_SECONDS=120
