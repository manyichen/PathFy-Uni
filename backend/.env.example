# 复制为 backend/.env 后填写真实值（勿提交 .env）

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace-with-a-random-secret
TOKEN_EXPIRES_HOURS=24

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=suilli_mizi

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Doubao(Ark) 岗位 AI 助手
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-mini-260215
AI_MAX_RETURN_JOBS=40
AI_CONTEXT_WINDOW=6
AI_LLM_TIMEOUT_SECONDS=90

# 外发 LLM / 本地存储隐私（默认开启脱敏；调试可设 LLM_PRIVACY_MODE=false）
LLM_PRIVACY_MODE=true
LLM_MAX_TEXT_CHARS=4000
LLM_MAX_RESUME_CHARS=6000
LLM_MAX_FIELD_CHARS=1200
LLM_STORE_RAW_SNIPPETS=false
LOCAL_STORE_RAW_RESUME_TEXT=false
LOCAL_STORE_RAW_REVIEW_TEXT=false
LOCAL_STORE_RAW_CHAT_MESSAGES=false
LOCAL_MAX_STORED_TEXT_CHARS=4000
DELETE_UPLOADED_RESUME_AFTER_OCR=true
API_CACHE_NO_STORE=true

FRONTEND_ORIGIN=http://localhost:4321

# 简历上传单文件大小上限（MB）
MAX_UPLOAD_MB=10
# 简历 OCR 临时目录（不在 Web 静态目录下；留空则用 backend/private_uploads/resumes）
# RESUME_UPLOAD_DIR=/var/private/pathfy/resumes

# 简历 OCR / 通义（按功能选用）
OCR_APP_ID=
OCR_API_KEY=
OCR_SECRET_KEY=
DASHSCOPE_API_KEY=

# 人岗匹配 POST /api/match/preview（Neo4j 粗排 + 可选 DeepSeek 精排）
MATCH_PREVIEW_MAX_SCAN=2000
MATCH_PREVIEW_MAX_SCAN_HARD=8000
MATCH_TOP_K_RETURN=30
MATCH_LLM_POOL_K=40
# 粗排：八维轮廓 Pearson 相关 + 软 surplus（岗位每维可略高于学生，见 match_preview._coarse_morphology_match）
MATCH_COARSE_SHAPE_WEIGHT=0.42
MATCH_GAP_SOFT_MARGIN_FIT=6
MATCH_GAP_SOFT_MARGIN_STRETCH=10
# 冲刺高质 match_goal=stretch：粗排分层与加权（见 match_preview._sort_ranked_for_goal）
MATCH_STRETCH_MATCH_SCORE_FLOOR=38
MATCH_STRETCH_SORT_W_MATCH=0.32
MATCH_STRETCH_SORT_W_JOB_AVG=0.68
DEEPSEEK_API_KEY=
MATCH_DEEPSEEK_MODEL=deepseek-chat
MATCH_LLM_TIMEOUT_SECONDS=120

# 生涯报告：DeepSeek（趋势/复盘/重规划）+ 豆包（报告文案）
CAREER_DEEPSEEK_MODEL=deepseek-chat
CAREER_ARK_MODEL=doubao-seed-2-0-lite-260215
CAREER_LLM_TIMEOUT_SECONDS=120
CAREER_LLM_MAX_RETRIES=2
# M3 复盘抽取 DeepSeek temperature（默认 0.55；想更稳可降到 0.35，想更发散可升到 0.8）
CAREER_REVIEW_EXTRACT_TEMPERATURE=0.55
CAREER_ENABLE_COPYWRITER=true
CAREER_ENABLE_PER_TARGET_COPYWRITER=true
CAREER_ENABLE_REPLAN_LLM=true
# 已废弃：生成报告时自动用 DeepSeek 改趋势分数（默认关闭）
CAREER_ENABLE_TREND_AUGMENT=false
# 用户点击「查看近期公开信息」时按需联网（JobTitle 缓存）
# 流程：① 网页检索（Serper 或免费 Jina）→ ② DeepSeek 归纳摘要（用 DEEPSEEK_API_KEY，非模型自带搜索）
CAREER_ENABLE_PUBLIC_INFO=true
CAREER_PUBLIC_INFO_CACHE_DAYS=14
CAREER_PUBLIC_INFO_MAX_SUMMARY_CHARS=300
CAREER_PUBLIC_SEARCH_MAX_CHARS=1200
# 可选：Serper 谷歌检索（推荐；未配置时会尝试 Jina Reader，国内网络可能失败）
SERPER_API_KEY=
# 生涯报告 DeepSeek 模型（策展/定制行动/公开信息摘要）；与 MATCH_DEEPSEEK_MODEL 可相同
# deepseek-chat 已路由到 v4-flash，但 API 仍无联网能力，不能替代 SERPER
# CAREER_DEEPSEEK_MODEL=deepseek-v4-flash
# 图谱推荐：竞赛 + 学习资源（经 JobTitle）
CAREER_ENABLE_GRAPH_RECOMMENDATIONS=true
CAREER_ENABLE_RECOMMENDATION_LLM=true
# enrich 阶段：DeepSeek batch 为各 job_id 生成定制行动（结合公司/缺口，禁止编造图谱外资源名）
CAREER_ENABLE_PLAN_CUSTOMIZATION=true
# 生成报告：前端默认 skip_llm_enrich=true 先出画布，再调 /report/{id}/enrich 做 batch 策展+豆包文案
CAREER_LR_POOL_PER_TARGET=18
CAREER_COMP_POOL_PER_TARGET=10
CAREER_LR_PER_TARGET=6
CAREER_COMP_PER_TARGET=3
