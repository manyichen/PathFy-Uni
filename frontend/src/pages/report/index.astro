---
import Layout from "@layouts/Layout.astro";
import CareerReportPanel from "@components/report/CareerReportPanel.svelte";
---

<Layout title="生涯报告" description="职业生涯发展报告生成与导出。">
	<section class="onload-animation space-y-6">
		<h1 class="text-2xl font-bold text-black dark:text-white">职业生涯发展报告</h1>
		<p class="text-75 max-w-3xl text-sm leading-relaxed">
			从人岗匹配云端记录导入 Top5，或手动选岗（最多 5 个），并生成短中期成长计划与评估指标。
		</p>
		<CareerReportPanel client:load />
	</section>
</Layout>
