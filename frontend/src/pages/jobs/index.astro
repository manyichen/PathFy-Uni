---
import JobsExplorer from "@components/jobs/JobsExplorer.svelte";
import Layout from "@layouts/Layout.astro";
---

<Layout title="岗位探索" description="检索与浏览岗位，查看岗位画像。">
	<section class="space-y-6">
		<div>
			<h1 class="text-2xl font-bold text-black dark:text-white">岗位探索</h1>
			<p class="text-75 mt-2 text-sm">卡片展示岗位、薪资、公司、地点，并结合 Neo4j 的八维能力数据绘制雷达图。</p>
		</div>
		<JobsExplorer client:load />
	</section>
</Layout>
