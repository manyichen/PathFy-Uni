---
import Layout from "@layouts/Layout.astro";

export function getStaticPaths() {
	return [{ params: { id: "demo" } }];
}

const { id } = Astro.params;
---

<Layout title={`岗位 ${id}`} description="岗位详情与画像（占位）。">
	<section class="onload-animation space-y-4">
		<h1 class="text-2xl font-bold text-black dark:text-white">
			岗位详情 <span class="text-[var(--primary)]">#{id}</span>
		</h1>
		<p class="text-75 text-sm">
			静态构建仅预生成 <code
				class="rounded bg-[var(--btn-regular-bg)] px-1.5 py-0.5 text-xs">demo</code
			>；其他 ID 需后端托管 SPA 回退或改为服务端路由。
		</p>
		<div
			class="card-base border border-black/5 p-6 text-sm text-75 dark:border-white/10"
		>
			<p>此处将展示：职位描述、薪资、画像雷达、证书与素质要求等（对接 <code>GET /api/jobs/{id}</code>）。</p>
		</div>
	</section>
</Layout>
