---
import Layout from '../../layouts/Layout.astro';
import RadarChart from '../../components/profile/RadarChart.svelte';
---

<Layout title="能力画像" description="学生就业能力画像分析，支持简历上传与表单录入。">
  <section class="onload-animation space-y-8">
    <div>
      <h1 class="mb-2 text-2xl font-bold text-black dark:text-white">学生就业能力画像</h1>
      <p class="max-w-3xl text-sm leading-relaxed text-75">
        支持简历上传与表单录入；后端通过大模型拆解为结构化画像，并给出完整度与竞争力评分。
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- 左侧：简历上传区 -->
      <div class="rounded-2xl border bg-background p-6 shadow-sm lg:col-span-1">
        <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">简历接入</h2>
        <div class="space-y-4">
          <div>
            <label class="mb-1 block font-medium text-black dark:text-white">姓名</label>
            <input type="text" id="nameInput" required class="w-full rounded-lg border bg-background px-3 py-2 text-sm text-black dark:border-gray-700 dark:bg-gray-800 dark:text-white" placeholder="请输入姓名" />
          </div>
          <div>
            <label class="mb-1 block font-medium text-black dark:text-white">专业</label>
            <input type="text" id="majorInput" required class="w-full rounded-lg border bg-background px-3 py-2 text-sm text-black dark:border-gray-700 dark:bg-gray-800 dark:text-white" placeholder="请输入专业" />
          </div>
          <div>
            <label class="mb-1 block font-medium text-black dark:text-white">上传简历（图片/PDF）</label>
            <input
              type="file"
              id="resumeInput"
              required
              class="w-full rounded-lg border bg-background px-3 py-2 text-sm text-black dark:border-gray-700 dark:bg-gray-800 dark:text-white"
              accept=".jpg,.jpeg,.png,.pdf"
            />
          </div>
          <button id="submitBtn" type="button" class="w-full rounded-lg bg-[var(--primary)] px-4 py-3 text-center text-sm font-medium text-white hover:bg-[var(--primary)]/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50">
            生成能力画像
          </button>
        </div>
      </div>

      <!-- 中间：能力雷达图 -->
      <div class="rounded-2xl border bg-background p-6 shadow-sm lg:col-span-1">
        <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">能力雷达</h2>
        <RadarChart client:load />

        <div class="mt-6 grid grid-cols-2 gap-2 text-sm">
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">专业理论知识：<span id="score_theory">0</span></div>
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">交叉学科广度：<span id="score_cross">0</span></div>
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">专业实践技能：<span id="score_practice">0</span></div>
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">数字素养技能：<span id="score_digital">0</span></div>
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">创新创业能力：<span id="score_innovation">0</span></div>
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">团队协作能力：<span id="score_teamwork">0</span></div>
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">社会实践网络：<span id="score_social">0</span></div>
          <div class="rounded bg-gray-50 p-2 text-center text-black dark:bg-gray-800 dark:text-white">学习与发展潜力：<span id="score_growth">0</span></div>
        </div>
      </div>

      <!-- 右侧：完整度和竞争度分析 -->
      <div class="rounded-2xl border bg-background p-6 shadow-sm lg:col-span-1">
        <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">能力评估</h2>
        
        <!-- 完整度和竞争度分数 -->
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="rounded-lg border bg-blue-50 p-4 text-center dark:border-blue-900/30 dark:bg-blue-900/10">
            <h3 class="text-sm font-medium text-blue-800 dark:text-blue-300 mb-2">能力完整度</h3>
            <div class="text-3xl font-bold text-blue-600 dark:text-blue-400" id="completeness_score">0</div>
            <div class="mt-2 h-2 bg-blue-200 rounded-full dark:bg-blue-800/50">
              <div class="h-2 bg-blue-600 rounded-full dark:bg-blue-400" style="width: 0%" id="completeness_bar"></div>
            </div>
          </div>
          <div class="rounded-lg border bg-green-50 p-4 text-center dark:border-green-900/30 dark:bg-green-900/10">
            <h3 class="text-sm font-medium text-green-800 dark:text-green-300 mb-2">就业竞争力</h3>
            <div class="text-3xl font-bold text-green-600 dark:text-green-400" id="competitiveness_score">0</div>
            <div class="mt-2 h-2 bg-green-200 rounded-full dark:bg-green-800/50">
              <div class="h-2 bg-green-600 rounded-full dark:bg-green-400" style="width: 0%" id="competitiveness_bar"></div>
            </div>
          </div>
        </div>

        <!-- 分析结果 -->
        <div class="space-y-4">
          <div class="rounded-lg border bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-800/50">
            <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">完整度分析</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400" id="completeness_analysis">请上传简历以获取分析结果</p>
          </div>
          <div class="rounded-lg border bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-800/50">
            <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">竞争力分析</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400" id="competitiveness_analysis">请上传简历以获取分析结果</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 详细分析报告：未分析前仅提示；分析完成后展示下方各卡片 -->
    <div id="detailed_analysis_section" class="space-y-6">
      <div
        id="profile_detailed_explore_hint"
        class="rounded-2xl border bg-background p-8 text-center shadow-sm"
      >
        <p class="mx-auto max-w-lg text-sm leading-relaxed text-75">
          请上传简历并完成分析，下面的区域以后再来探索吧~
        </p>
      </div>

      <div id="profile_detailed_cards" class="hidden space-y-6">
      <!-- 整体评价 -->
      <div class="rounded-2xl border bg-background p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">📊 整体评价</h2>
        <div class="rounded-lg border bg-gradient-to-r from-blue-50 to-purple-50 p-4 dark:border-blue-900/30 dark:from-blue-900/10 dark:to-purple-900/10">
          <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300" id="overall_evaluation">-</p>
        </div>
      </div>

      <!-- 优势与劣势维度 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- 优势维度 -->
        <div class="rounded-2xl border bg-background p-6 shadow-sm">
          <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">💪 优势维度</h2>
          <div class="space-y-3" id="advantage_dimensions">
            <!-- 动态填充 -->
          </div>
        </div>

        <!-- 劣势维度 -->
        <div class="rounded-2xl border bg-background p-6 shadow-sm">
          <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">📚 待提升维度</h2>
          <div class="space-y-3" id="劣势_dimensions">
            <!-- 动态填充 -->
          </div>
        </div>
      </div>

      <!-- 各维度详细分析 -->
      <div class="rounded-2xl border bg-background p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">🔍 各维度详细分析</h2>
        <div class="space-y-4" id="dimension_analysis">
          <!-- 动态填充 -->
        </div>
      </div>

      <!-- 发展计划 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- 短期提升计划 -->
        <div class="rounded-2xl border bg-background p-6 shadow-sm">
          <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">📅 短期提升计划（3-6个月）</h2>
          <div class="space-y-4" id="short_term_plan">
            <!-- 动态填充 -->
          </div>
        </div>

        <!-- 长期发展目标 -->
        <div class="rounded-2xl border bg-background p-6 shadow-sm">
          <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">🎯 长期发展目标（1-2年）</h2>
          <div class="space-y-4" id="long_term_goals">
            <!-- 动态填充 -->
          </div>
        </div>
      </div>

      <!-- 行业适配性分析 -->
      <div class="rounded-2xl border bg-background p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">🏢 行业适配性分析</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4" id="industry_match">
          <!-- 动态填充 -->
        </div>
      </div>

      <!-- 简历关键词分析 -->
      <div class="rounded-2xl border bg-background p-6 shadow-sm" id="resume_analysis_section">
        <h2 class="mb-4 text-lg font-semibold text-black dark:text-white">📝 简历关键词分析</h2>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-600 dark:text-gray-400">技能密度</span>
            <span class="text-sm font-medium text-[var(--primary)]" id="skill_density">-</span>
          </div>
          <div class="h-2 bg-gray-200 rounded-full dark:bg-gray-700">
            <div class="h-2 bg-[var(--primary)] rounded-full" style="width: 0%" id="skill_density_bar"></div>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="found_keywords">
            <!-- 动态填充 -->
          </div>
          <div class="rounded-lg border bg-yellow-50 p-4 dark:border-yellow-900/30 dark:bg-yellow-900/10">
            <h3 class="text-sm font-medium text-yellow-800 dark:text-yellow-300 mb-2">优化建议</h3>
            <ul class="space-y-1 text-sm text-yellow-700 dark:text-yellow-400" id="keyword_suggestions">
              <!-- 动态填充 -->
            </ul>
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { getToken, getUser } from '../../lib/auth';
  import { fetchMyResumes } from '../../lib/match';
  import { fetchResumePortraitResult, uploadResume } from '../../lib/profile';
  import {
    emitProfileRadarScores,
    loadPortraitLocalCache,
    paintProfilePortraitPage,
    savePortraitLocalCache,
  } from '../../lib/profile-portrait-ui';

  function hasPortraitDetailedAnalysis(d: unknown): boolean {
    if (!d || typeof d !== 'object') return false;
    const o = d as Record<string, unknown>;
    const oe = o.overall_evaluation;
    if (typeof oe === 'string' && oe.trim().length > 0) return true;
    const dim = o.dimension_analysis;
    return Array.isArray(dim) && dim.length > 0;
  }

  function setPortraitLowerInsightsMode(mode: 'explore' | 'detailed') {
    const hint = document.getElementById('profile_detailed_explore_hint');
    const cards = document.getElementById('profile_detailed_cards');
    if (!hint || !cards) return;
    if (mode === 'explore') {
      hint.classList.remove('hidden');
      cards.classList.add('hidden');
    } else {
      hint.classList.add('hidden');
      cards.classList.remove('hidden');
    }
  }

  function generateCompletenessAnalysis(completeness, scores) {
    if (completeness >= 90) {
      return '您的能力覆盖非常全面，各维度发展均衡，展现了良好的综合能力素质。建议继续保持各维度的发展，同时可以尝试在特定领域进行深度拓展。';
    } else if (completeness >= 70) {
      return '您的能力覆盖较为全面，大部分维度发展良好。建议关注发展相对薄弱的维度，如' + getWeakDimensions(scores) + '，以提升整体能力的完整性。';
    } else if (completeness >= 50) {
      return '您的能力覆盖存在一定的不平衡，部分维度发展较好，但其他维度相对薄弱。建议重点加强' + getWeakDimensions(scores) + '等维度的培养，以提高能力的整体完整性。';
    } else {
      return '您的能力覆盖较为有限，多个维度发展不足。建议系统性地提升各维度能力，特别是' + getWeakDimensions(scores) + '等核心维度，以建立更加完整的能力体系。';
    }
  }

  function generateCompetitivenessAnalysis(competitiveness, scores) {
    if (competitiveness >= 90) {
      return '您的就业竞争力非常强，在各维度都展现出了突出的能力。建议保持优势，同时关注行业最新发展趋势，持续提升专业技能，以保持竞争力。';
    } else if (competitiveness >= 70) {
      return '您的就业竞争力较强，在多个维度表现良好。建议强化' + getStrongDimensions(scores) + '等优势维度，同时提升' + getWeakDimensions(scores) + '等薄弱环节，以进一步增强竞争力。';
    } else if (competitiveness >= 50) {
      return '您的就业竞争力处于中等水平，有一定的优势但也存在明显的不足。建议重点提升' + getWeakDimensions(scores) + '等维度，同时加强实践经验和项目经历的积累。';
    } else {
      return '您的就业竞争力相对较弱，需要全面提升各维度能力。建议从' + getWeakDimensions(scores) + '等基础维度入手，逐步建立核心竞争力，同时积累相关实践经验。';
    }
  }

  function getWeakDimensions(scores) {
    const dimensions = [
      { name: '专业理论知识', value: scores.cap_req_theory },
      { name: '交叉学科广度', value: scores.cap_req_cross },
      { name: '专业实践技能', value: scores.cap_req_practice },
      { name: '数字素养技能', value: scores.cap_req_digital },
      { name: '创新创业能力', value: scores.cap_req_innovation },
      { name: '团队协作能力', value: scores.cap_req_teamwork },
      { name: '社会实践网络', value: scores.cap_req_social },
      { name: '学习与发展潜力', value: scores.cap_req_growth }
    ];
    return dimensions
      .sort((a, b) => a.value - b.value)
      .slice(0, 2)
      .map(d => d.name)
      .join('、');
  }

  function getStrongDimensions(scores) {
    const dimensions = [
      { name: '专业理论知识', value: scores.cap_req_theory },
      { name: '交叉学科广度', value: scores.cap_req_cross },
      { name: '专业实践技能', value: scores.cap_req_practice },
      { name: '数字素养技能', value: scores.cap_req_digital },
      { name: '创新创业能力', value: scores.cap_req_innovation },
      { name: '团队协作能力', value: scores.cap_req_teamwork },
      { name: '社会实践网络', value: scores.cap_req_social },
      { name: '学习与发展潜力', value: scores.cap_req_growth }
    ];
    return dimensions
      .sort((a, b) => b.value - a.value)
      .slice(0, 2)
      .map(d => d.name)
      .join('、');
  }

  function renderDetailedAnalysis(analysisData: Record<string, unknown>) {
    const overallEl = document.getElementById('overall_evaluation');
    if (overallEl) {
      overallEl.textContent =
        typeof analysisData.overall_evaluation === 'string'
          ? analysisData.overall_evaluation
          : '';
    }

    const advantageContainer = document.getElementById('advantage_dimensions');
    if (!advantageContainer) return;
    advantageContainer.innerHTML = '';
    if (analysisData.advantage_dimensions && analysisData.advantage_dimensions.length > 0) {
      analysisData.advantage_dimensions.forEach(item => {
        advantageContainer.innerHTML += `
          <div class="flex items-center justify-between rounded-lg border border-green-200 bg-green-50 p-3 dark:border-green-900/30 dark:bg-green-900/10">
            <span class="text-sm font-medium text-green-800 dark:text-green-300">${item.dimension}</span>
            <span class="text-sm font-bold text-green-600 dark:text-green-400">${item.score}分</span>
          </div>
        `;
      });
    } else {
      advantageContainer.innerHTML = '<p class="text-sm text-75">暂无优势维度数据</p>';
    }

    const weaknessContainer = document.getElementById('劣势_dimensions');
    if (!weaknessContainer) return;
    weaknessContainer.innerHTML = '';
    if (analysisData.劣势_dimensions && analysisData.劣势_dimensions.length > 0) {
      analysisData.劣势_dimensions.forEach(item => {
        weaknessContainer.innerHTML += `
          <div class="flex items-center justify-between rounded-lg border border-orange-200 bg-orange-50 p-3 dark:border-orange-900/30 dark:bg-orange-900/10">
            <span class="text-sm font-medium text-orange-800 dark:text-orange-300">${item.dimension}</span>
            <span class="text-sm font-bold text-orange-600 dark:text-orange-400">${item.score}分</span>
          </div>
        `;
      });
    } else {
      weaknessContainer.innerHTML = '<p class="text-sm text-75">暂无待提升维度数据</p>';
    }

    const dimensionContainer = document.getElementById('dimension_analysis');
    if (!dimensionContainer) return;
    dimensionContainer.innerHTML = '';
    if (analysisData.dimension_analysis && analysisData.dimension_analysis.length > 0) {
      analysisData.dimension_analysis.forEach(item => {
        const levelColor = item.level === '高' ? 'green' : (item.level === '中' ? 'blue' : 'orange');
        dimensionContainer.innerHTML += `
          <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-800/50">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200">${item.dimension}</h3>
              <div class="flex items-center gap-2">
                <span class="text-lg font-bold text-${levelColor}-600 dark:text-${levelColor}-400">${item.score}分</span>
                <span class="rounded-full px-2 py-0.5 text-xs font-medium bg-${levelColor}-100 text-${levelColor}-800 dark:bg-${levelColor}-900/30 dark:text-${levelColor}-300">${item.level}</span>
              </div>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">${item.interpretation}</p>
          </div>
        `;
      });
    } else {
      dimensionContainer.innerHTML = '<p class="text-sm text-75">暂无各维度详细分析</p>';
    }

    const shortTermContainer = document.getElementById('short_term_plan');
    if (!shortTermContainer) return;
    shortTermContainer.innerHTML = '';
    if (analysisData.short_term_plan && analysisData.short_term_plan.length > 0) {
      analysisData.short_term_plan.forEach(item => {
        shortTermContainer.innerHTML += `
          <div class="rounded-lg border border-blue-200 bg-blue-50 p-4 dark:border-blue-900/30 dark:bg-blue-900/10">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold text-blue-800 dark:text-blue-300">${item.dimension}</h3>
              <span class="text-sm text-blue-600 dark:text-blue-400">当前：${item.current_score}分</span>
            </div>
            <ul class="space-y-1">
              ${(item.suggestions || []).map(s => `<li class="text-sm text-blue-700 dark:text-blue-400">• ${s}</li>`).join('')}
            </ul>
          </div>
        `;
      });
    } else {
      shortTermContainer.innerHTML = '<p class="text-sm text-75">暂无短期提升计划</p>';
    }

    const longTermContainer = document.getElementById('long_term_goals');
    if (!longTermContainer) return;
    longTermContainer.innerHTML = '';
    if (analysisData.long_term_goals && analysisData.long_term_goals.length > 0) {
      analysisData.long_term_goals.forEach(item => {
        const goalTypeColor = item.goal_type === '重点培养' ? 'orange' : 'green';
        longTermContainer.innerHTML += `
          <div class="rounded-lg border border-${goalTypeColor}-200 bg-${goalTypeColor}-50 p-4 dark:border-${goalTypeColor}-900/30 dark:bg-${goalTypeColor}-900/10">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold text-${goalTypeColor}-800 dark:text-${goalTypeColor}-300">${item.dimension}</h3>
              <span class="rounded-full px-2 py-0.5 text-xs font-medium bg-${goalTypeColor}-100 text-${goalTypeColor}-800 dark:bg-${goalTypeColor}-900/30 dark:text-${goalTypeColor}-300">${item.goal_type}</span>
            </div>
            <p class="text-sm text-${goalTypeColor}-700 dark:text-${goalTypeColor}-400 mb-2">当前水平：${item.current_score}分</p>
            <ul class="space-y-1">
              ${(item.suggestions || []).map(s => `<li class="text-sm text-${goalTypeColor}-700 dark:text-${goalTypeColor}-400">• ${s}</li>`).join('')}
            </ul>
          </div>
        `;
      });
    } else {
      longTermContainer.innerHTML = '<p class="text-sm text-75">暂无长期发展目标</p>';
    }

    const industryContainer = document.getElementById('industry_match');
    if (!industryContainer) return;
    industryContainer.innerHTML = '';
    if (analysisData.industry_match && analysisData.industry_match.length > 0) {
      analysisData.industry_match.slice(0, 4).forEach(item => {
        industryContainer.innerHTML += `
          <div class="rounded-lg border border-purple-200 bg-purple-50 p-4 dark:border-purple-900/30 dark:bg-purple-900/10">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold text-purple-800 dark:text-purple-300">${item.industry}</h3>
              <span class="text-lg font-bold text-purple-600 dark:text-purple-400">${item.match_score}</span>
            </div>
            <p class="text-xs text-purple-700 dark:text-purple-400 mb-2">核心能力：${item.core_abilities.join('、')}</p>
            <p class="text-xs text-purple-600 dark:text-purple-500">${item.description}</p>
          </div>
        `;
      });
    } else {
      industryContainer.innerHTML = '<p class="text-sm text-75">暂无行业适配性分析</p>';
    }

    const resumeSection = document.getElementById('resume_analysis_section');
    const skillDensityEl = document.getElementById('skill_density');
    const skillDensityBar = document.getElementById('skill_density_bar') as HTMLElement | null;
    const keywordsContainer = document.getElementById('found_keywords');
    const suggestionsContainer = document.getElementById('keyword_suggestions');
    if (!resumeSection || !skillDensityEl || !skillDensityBar || !keywordsContainer || !suggestionsContainer) return;

    resumeSection.classList.remove('hidden');

    const resumeAnalysis = analysisData.resume_analysis as Record<string, unknown> | undefined;
    if (resumeAnalysis && typeof resumeAnalysis === 'object' && Object.keys(resumeAnalysis).length > 0) {
      const densityRaw = resumeAnalysis.skill_density;
      const density =
        typeof densityRaw === 'number' ? densityRaw : Number.parseInt(String(densityRaw ?? 0), 10) || 0;
      skillDensityEl.textContent = `${density}%`;
      skillDensityBar.style.width = `${density}%`;

      keywordsContainer.innerHTML = '';
      const foundKeywords = (resumeAnalysis.found_keywords || {}) as Record<string, string[]>;
      for (const [category, keywords] of Object.entries(foundKeywords)) {
        if (keywords && keywords.length > 0) {
          keywordsContainer.innerHTML += `
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-800/50">
              <h4 class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">${category}</h4>
              <div class="flex flex-wrap gap-1">
                ${keywords.map(k => `<span class="rounded bg-blue-100 px-1.5 py-0.5 text-xs text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">${k}</span>`).join('')}
              </div>
            </div>
          `;
        }
      }

      suggestionsContainer.innerHTML = '';
      const sugg = resumeAnalysis.suggestions;
      if (Array.isArray(sugg)) {
        sugg.forEach((suggestion: string) => {
          suggestionsContainer.innerHTML += `<li>• ${suggestion}</li>`;
        });
      }
    } else {
      skillDensityEl.textContent = '0%';
      skillDensityBar.style.width = '0%';
      keywordsContainer.innerHTML = '<p class="text-sm text-75">暂无关键词分析数据</p>';
      suggestionsContainer.innerHTML = '';
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
    const nameInput = document.getElementById('nameInput') as HTMLInputElement | null;
    const majorInput = document.getElementById('majorInput') as HTMLInputElement | null;
    const resumeInput = document.getElementById('resumeInput') as HTMLInputElement | null;
    if (!submitBtn || !nameInput || !majorInput || !resumeInput) return;

    const token = getToken();
    const user = getUser();
    let detailedUnlocked = false;

    if (token && user?.id) {
      try {
        const resumes = await fetchMyResumes();
        if (resumes.length > 0) {
          const r = resumes[0];
          const completeness = typeof r.completeness === 'number' ? r.completeness : 0;
          const competitiveness = typeof r.competitiveness === 'number' ? r.competitiveness : 0;
          paintProfilePortraitPage({
            scores: { ...r.scores },
            completeness,
            competitiveness,
            name: r.name,
            major: r.major,
          });
          setTimeout(() => emitProfileRadarScores({ ...r.scores }), 200);

          const row = await fetchResumePortraitResult(r.id);
          const da = row?.detailed_analysis;
          if (hasPortraitDetailedAnalysis(da)) {
            renderDetailedAnalysis(da as Record<string, unknown>);
            setPortraitLowerInsightsMode('detailed');
            detailedUnlocked = true;
          }
        } else {
          const cached = loadPortraitLocalCache(user.id);
          if (cached) {
            paintProfilePortraitPage({
              scores: cached.scores,
              completeness: cached.completeness,
              competitiveness: cached.competitiveness,
              name: cached.name,
              major: cached.major,
            });
            setTimeout(() => emitProfileRadarScores(cached.scores), 200);
          }
        }
      } catch {
        const cached = user?.id ? loadPortraitLocalCache(user.id) : null;
        if (cached) {
          paintProfilePortraitPage({
            scores: cached.scores,
            completeness: cached.completeness,
            competitiveness: cached.competitiveness,
            name: cached.name,
            major: cached.major,
          });
          setTimeout(() => emitProfileRadarScores(cached.scores), 200);
        }
      }
    }

    if (!detailedUnlocked) {
      setPortraitLowerInsightsMode('explore');
    }

    submitBtn.addEventListener('click', async () => {
      if (!nameInput.value || !majorInput.value || !resumeInput.files?.length) {
        alert('请填写完整信息并上传简历');
        return;
      }

      const u = getUser();
      if (!u?.id) {
        alert('请先登录后再生成能力画像');
        return;
      }

      const formData = new FormData();
      formData.append('name', nameInput.value);
      formData.append('major', majorInput.value);
      formData.append('resume', resumeInput.files[0]);
      formData.append('user_id', String(u.id));

      submitBtn.disabled = true;
      submitBtn.textContent = '分析中...';

      try {
        const result = await uploadResume(formData);
        const scores = result.scores;
        const completeness = result.completeness;
        const competitiveness = result.competitiveness;

        const da = result.detailed_analysis;
        if (hasPortraitDetailedAnalysis(da)) {
          renderDetailedAnalysis((da || {}) as Record<string, unknown>);
          setPortraitLowerInsightsMode('detailed');
        } else {
          setPortraitLowerInsightsMode('explore');
        }
        paintProfilePortraitPage({
          scores,
          completeness,
          competitiveness,
          name: nameInput.value,
          major: majorInput.value,
        });
        savePortraitLocalCache(u.id, {
          scores,
          completeness,
          competitiveness,
          name: nameInput.value,
          major: majorInput.value,
        });

        alert('✅ 分析完成！能力画像已生成');
        setTimeout(() => emitProfileRadarScores(scores), 200);
      } catch (err) {
        console.error(err);
        alert('❌ 上传失败：' + (err instanceof Error ? err.message : '未知错误'));
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = '生成能力画像';
      }
    });
  });
</script>
