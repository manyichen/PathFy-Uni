---
import ResumeDropZone from "@components/interactive/ResumeDropZone.svelte";
import SkillRadarDemo from "@components/interactive/SkillRadarDemo.svelte";
import Layout from "@layouts/Layout.astro";
---

<Layout title="能力画像" description="简历解析与就业能力画像。">
	<section class="onload-animation space-y-8">
		<div>
			<h1 class="mb-2 text-2xl font-bold text-black dark:text-white">学生就业能力画像</h1>
			<p class="max-w-3xl text-sm leading-relaxed text-75">
				支持<strong>简历上传</strong>与<strong>表单录入</strong>；后端通过大模型拆解为结构化画像，并给出<strong
					>完整度</strong
				>与<strong>竞争力</strong>评分。联调接口示例：<code
					class="rounded bg-[var(--btn-regular-bg)] px-1.5 py-0.5 text-xs"
					>POST /api/resume/upload</code
				>、<code class="rounded bg-[var(--btn-regular-bg)] px-1.5 py-0.5 text-xs"
					>POST /api/profile</code
				>。
			</p>
		</div>

		<div class="grid gap-8 lg:grid-cols-2">
			<div class="space-y-4">
				<h2 class="text-lg font-semibold text-black dark:text-white">简历接入</h2>
				<ResumeDropZone client:visible />
			</div>
			<div class="space-y-4">
				<h2 class="text-lg font-semibold text-black dark:text-white">能力雷达</h2>
				<SkillRadarDemo client:visible />
			</div>
		</div>
	</section>
</Layout>
