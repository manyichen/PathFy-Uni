---
import { Icon } from "astro-icon/components";

const radarAxes = [
	{ key: "cap_req_theory", label: "理论", value: 68 },
	{ key: "cap_req_cross", label: "交叉", value: 55 },
	{ key: "cap_req_practice", label: "实践", value: 82 },
	{ key: "cap_req_digital", label: "数字", value: 79 },
	{ key: "cap_req_innovation", label: "创新", value: 41 },
	{ key: "cap_req_teamwork", label: "协作", value: 70 },
	{ key: "cap_req_social", label: "社会", value: 36 },
	{ key: "cap_req_growth", label: "成长", value: 64 },
];

const metrics = [
	{ label: "岗位样本", value: "10,000+", icon: "material-symbols:work-outline" },
	{ label: "画像维度", value: "8 维", icon: "material-symbols:person-search-outline" },
	{ label: "规划输出", value: "短/中期", icon: "material-symbols:article-outline" },
];

const workflow = [
	{ title: "探索岗位", desc: "拆解市场能力要求", icon: "material-symbols:travel-explore-rounded" },
	{ title: "生成画像", desc: "识别优势与短板", icon: "material-symbols:radar" },
	{ title: "匹配分析", desc: "查看差距与原因", icon: "material-symbols:compare-arrows-rounded" },
	{ title: "行动计划", desc: "沉淀阶段任务", icon: "material-symbols:task-alt-rounded" },
];

const focusItems = [
	{ label: "实践技能", value: 82 },
	{ label: "数字素养", value: 79 },
	{ label: "团队协作", value: 70 },
];

const radarN = radarAxes.length;
const radarCx = 120;
const radarCy = 120;
const radarMaxR = 82;

function radarPoint(index: number, value: number) {
	const angle = -Math.PI / 2 + (index * 2 * Math.PI) / radarN;
	const r = (value / 100) * radarMaxR;
	return {
		x: radarCx + r * Math.cos(angle),
		y: radarCy + r * Math.sin(angle),
	};
}

const radarPolygonPoints = radarAxes
	.map((axis, index) => {
		const p = radarPoint(index, axis.value);
		return `${p.x},${p.y}`;
	})
	.join(" ");
---

<section
	id="home-hero"
	class="relative left-1/2 mb-10 w-screen -translate-x-1/2 overflow-hidden border-y border-black/10 bg-slate-950 text-white dark:border-white/10"
	aria-labelledby="hero-title"
>
	<img
		src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1800&q=82"
		alt=""
		aria-hidden="true"
		class="absolute inset-0 h-full w-full object-cover opacity-70"
		loading="eager"
		decoding="async"
	/>
	<div
		class="absolute inset-0"
		style="background: linear-gradient(90deg, rgba(2, 6, 23, 0.96) 0%, rgba(15, 23, 42, 0.82) 46%, rgba(13, 148, 136, 0.56) 100%), linear-gradient(0deg, rgba(2, 6, 23, 0.42), rgba(2, 6, 23, 0.06));"
	>
	</div>

	<div class="relative mx-auto max-w-[var(--page-width)] px-4 py-7 md:px-6 lg:py-14">
		<div class="max-w-3xl">
			<p
				class="mb-4 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur"
			>
				<Icon name="material-symbols:route-outline" class="text-base text-teal-200" />
				大学生就业规划工作台
			</p>
			<h1
				id="hero-title"
				class="max-w-2xl text-4xl font-bold leading-tight tracking-normal text-white md:text-5xl lg:text-6xl"
			>
				职业规划智能体
			</h1>
			<p class="mt-4 max-w-2xl text-base leading-7 text-white/[0.82] md:text-lg md:leading-8">
				把岗位数据、能力画像、人岗匹配和生涯报告放在同一个流程里，让职业方向不再停留在想法，而是变成可解释、可执行、可复盘的计划。
			</p>
			<div class="mt-6 flex flex-wrap items-center gap-3">
				<a
					href="/profile/"
					class="inline-flex h-11 items-center gap-2 rounded-lg bg-white px-5 text-sm font-semibold text-slate-950 shadow-lg shadow-black/20 transition hover:-translate-y-0.5 hover:bg-teal-50 active:translate-y-0"
				>
					<Icon name="material-symbols:upload-file-outline" class="text-lg text-teal-700" />
					开始能力画像
				</a>
				<a
					href="/jobs/"
					class="inline-flex h-11 items-center gap-2 rounded-lg border border-white/25 bg-white/10 px-5 text-sm font-semibold text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/[0.16] active:translate-y-0"
				>
					<Icon name="material-symbols:work-outline" class="text-lg text-cyan-200" />
					浏览岗位库
				</a>
			</div>
		</div>

		<div class="mt-6 grid gap-3 lg:grid-cols-[1.05fr_0.95fr]">
			<div class="rounded-lg border border-white/[0.15] bg-slate-950/[0.55] p-4 shadow-2xl shadow-black/25 backdrop-blur-md">
				<div class="flex flex-wrap items-center justify-between gap-3">
					<div>
						<p class="text-xs font-semibold uppercase text-teal-200">Planning Console</p>
						<h2 class="mt-1 text-lg font-semibold tracking-normal text-white">从岗位探索到行动计划</h2>
					</div>
					<span class="rounded-full bg-emerald-400/[0.15] px-3 py-1 text-xs font-medium text-emerald-100">
						闭环流程
					</span>
				</div>

				<div class="mt-4 grid grid-cols-3 gap-2">
					{
						metrics.map((metric) => (
							<div class="rounded-lg border border-white/10 bg-white/[0.08] p-2.5 md:p-3">
								<Icon name={metric.icon} class="text-lg text-cyan-200 md:text-xl" />
								<p class="mt-2 text-[11px] text-white/60 md:text-xs">{metric.label}</p>
								<p class="text-base font-semibold text-white md:text-lg">{metric.value}</p>
							</div>
						))
					}
				</div>

				<div class="mt-4 hidden gap-2 sm:grid sm:grid-cols-2 lg:grid-cols-4">
					{
						workflow.map((step, index) => (
							<div class="relative rounded-lg border border-white/10 bg-white/[0.08] p-3">
								<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/[0.12] text-cyan-100">
									<Icon name={step.icon} class="text-lg" />
								</div>
								<p class="mt-2 text-sm font-semibold text-white">{step.title}</p>
								<p class="mt-1 text-xs leading-5 text-white/[0.62]">{step.desc}</p>
								<span class="absolute right-3 top-3 text-xs font-semibold text-white/[0.35]">
									0{index + 1}
								</span>
							</div>
						))
					}
				</div>
			</div>

			<div class="hidden gap-3 md:grid md:grid-cols-[0.92fr_1.08fr] lg:grid-cols-1 xl:grid-cols-[0.92fr_1.08fr]">
				<div class="rounded-lg border border-white/[0.15] bg-slate-950/[0.55] p-4 backdrop-blur-md">
					<div class="flex items-center justify-between gap-3">
						<h2 class="text-sm font-semibold tracking-normal text-white">能力画像预览</h2>
						<span class="rounded-full bg-cyan-300/[0.15] px-2 py-0.5 text-xs text-cyan-100">八维</span>
					</div>
					<div class="mt-2 flex justify-center">
						<svg width="214" height="214" viewBox="0 0 240 240" class="max-w-full" aria-hidden="true">
							{
								[0.25, 0.5, 0.75, 1].map((tier) => (
									<polygon
										points={radarAxes
											.map((_, i) => {
												const p = radarPoint(i, 100 * tier);
												return `${p.x},${p.y}`;
											})
											.join(" ")}
										fill="none"
										stroke="rgba(255,255,255,0.18)"
										stroke-width="1"
									/>
								))
							}
							{
								radarAxes.map((axis, i) => {
									const linePoint = radarPoint(i, 100);
									const labelPoint = radarPoint(i, 112);
									return (
										<>
											<line
												x1={radarCx}
												y1={radarCy}
												x2={linePoint.x}
												y2={linePoint.y}
												stroke="rgba(255,255,255,0.16)"
												stroke-width="1"
											/>
											<text
												x={labelPoint.x}
												y={labelPoint.y}
												text-anchor="middle"
												dominant-baseline="middle"
												class="fill-white/70 text-[9px]"
											>
												{axis.label}
											</text>
										</>
									);
								})
							}
							<polygon
								points={radarPolygonPoints}
								fill="rgba(45, 212, 191, 0.32)"
								stroke="rgb(94, 234, 212)"
								stroke-width="2.5"
							/>
							<circle cx={radarCx} cy={radarCy} r="3" fill="rgb(252, 211, 77)"></circle>
						</svg>
					</div>
				</div>

				<div class="rounded-lg border border-white/[0.15] bg-slate-950/[0.55] p-4 backdrop-blur-md">
					<h2 class="text-sm font-semibold tracking-normal text-white">当前优势</h2>
					<div class="mt-4 space-y-3">
						{
							focusItems.map((item) => (
								<div>
									<div class="flex items-center justify-between gap-3 text-xs">
										<span class="text-white/70">{item.label}</span>
										<span class="font-semibold text-amber-200">{item.value}%</span>
									</div>
									<div class="mt-1.5 h-2 overflow-hidden rounded-full bg-white/10">
										<div
											class="h-full rounded-full bg-gradient-to-r from-teal-300 to-amber-200"
											style={`width: ${item.value}%;`}
										></div>
									</div>
								</div>
							))
						}
					</div>
					<a
						href="/match/"
						class="mt-5 inline-flex h-10 w-full items-center justify-center gap-2 rounded-lg bg-teal-300 text-sm font-semibold text-slate-950 transition hover:bg-teal-200"
					>
						进入匹配分析
						<Icon name="material-symbols:arrow-forward-rounded" class="text-lg" />
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
