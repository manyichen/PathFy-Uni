---
import { Icon } from "astro-icon/components";

const radarAxes = [
	{ key: "cap_req_theory", label: "理论知识", value: 68 },
	{ key: "cap_req_cross", label: "交叉广度", value: 55 },
	{ key: "cap_req_practice", label: "实践技能", value: 82 },
	{ key: "cap_req_digital", label: "数字素养", value: 79 },
	{ key: "cap_req_innovation", label: "创新创业", value: 41 },
	{ key: "cap_req_teamwork", label: "团队协作", value: 70 },
	{ key: "cap_req_social", label: "社会实践", value: 36 },
	{ key: "cap_req_growth", label: "学习发展", value: 64 },
];

const radarN = radarAxes.length;
const radarCx = 120;
const radarCy = 120;
const radarMaxR = 86;

function radarPoint(index: number, value: number) {
	const angle = -Math.PI / 2 + (index * 2 * Math.PI) / radarN;
	const r = (value / 100) * radarMaxR;
	return {
		x: radarCx + r * Math.cos(angle),
		y: radarCy + r * Math.sin(angle),
	};
}

const radarPolygonPoints = radarAxes
	.map((axis, index) => {
		const p = radarPoint(index, axis.value);
		return `${p.x},${p.y}`;
	})
	.join(" ");
---

<section
	id="home-hero"
	class="relative mb-10 overflow-hidden rounded-[1.25rem] border border-black/10 dark:border-white/10"
	aria-labelledby="hero-title"
>
	<!-- 动态背景层 -->
	<div
		class="ca-gradient-flow absolute inset-0 opacity-90 dark:opacity-40"
		style="background-image: linear-gradient(125deg, oklch(0.92 0.06 var(--hue)), oklch(0.88 0.1 var(--hue)), oklch(0.95 0.04 var(--hue)), oklch(0.9 0.08 var(--hue)));"
	>
	</div>
	<div
		class="pointer-events-none absolute inset-0 hidden bg-gradient-to-b from-[var(--page-bg)]/80 to-transparent dark:block"
	>
	</div>
	<div
		class="pointer-events-none absolute -left-20 top-10 h-56 w-56 rounded-full bg-[var(--primary)] opacity-25 blur-3xl ca-blob"
	>
	</div>
	<div
		class="ca-blob ca-blob-delay-1 pointer-events-none absolute -right-16 bottom-0 h-48 w-48 rounded-full bg-[oklch(0.75_0.12_var(--hue))] opacity-30 blur-3xl"
	>
	</div>
	<div
		class="ca-blob ca-blob-delay-2 pointer-events-none absolute left-1/3 top-1/2 h-32 w-32 rounded-full bg-white opacity-20 blur-2xl dark:bg-white/10"
	>
	</div>

	<div class="ca-glass relative z-[1] px-6 pb-24 pt-12 md:px-12 md:pb-28 md:pt-16 lg:pb-32">
		<div class="grid gap-4 lg:grid-cols-[1.15fr_0.85fr]">
			<article class="rounded-2xl border border-black/10 bg-white/45 p-6 backdrop-blur-sm dark:border-white/15 dark:bg-black/10 md:p-8">
				<p
					class="mb-3 inline-flex items-center gap-2 rounded-full border border-black/10 bg-black/5 px-3 py-1 text-xs font-medium text-75 dark:border-white/15 dark:bg-white/5"
				>
					<span class="relative flex h-2 w-2">
						<span
							class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--primary)] opacity-60"
						></span>
						<span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--primary)]"></span>
					</span>
					智能计算 · 职业规划
				</p>
				<h1
					id="hero-title"
					class="mb-4 max-w-3xl text-3xl font-extrabold leading-tight tracking-tight md:text-4xl lg:text-[2.75rem]"
				>
					<span class="ca-text-shimmer">AI 驱动的人岗匹配</span>
					<span class="mt-1 block text-black dark:text-white">与可落地的生涯路径</span>
				</h1>
				<p class="mb-4 max-w-2xl text-base leading-relaxed text-75 md:text-lg">
					面向大学生就业场景，我们将岗位数据、能力模型与大模型分析结合，帮助你完成从“了解市场”到“明确方向”再到“执行计划”的完整规划流程。
				</p>
				<p class="mb-8 max-w-2xl text-sm leading-7 text-75 md:text-base">
					平台重点解决三类核心问题：<strong class="text-[var(--primary)]">职业信息不对称</strong>、
					<strong class="text-[var(--primary)]">自我能力认知模糊</strong>、<strong class="text-[var(--primary)]"
						>规划建议难落地</strong
					>，让每一步建议都有依据、可追踪、可调整。
				</p>
				<div class="flex flex-wrap items-center gap-3">
					<a
						href="/profile/"
						class="btn-regular group inline-flex items-center gap-2 rounded-xl px-6 py-3 font-semibold shadow-lg shadow-black/5 transition hover:scale-[1.02] active:scale-[0.98] dark:shadow-none"
					>
						<Icon name="material-symbols:upload-file-outline" class="text-xl" />
						开始能力画像
					</a>
					<a
						href="/match/"
						class="inline-flex items-center gap-2 rounded-xl border border-black/15 bg-white/50 px-5 py-3 font-medium text-90 backdrop-blur-sm transition hover:border-[var(--primary)]/50 hover:bg-white/80 dark:border-white/20 dark:bg-white/5 dark:hover:bg-white/10"
					>
						<Icon name="material-symbols:hub-outline" class="text-xl text-[var(--primary)]" />
						试玩匹配沙盘
					</a>
				</div>
			</article>

			<article class="rounded-2xl border border-black/10 bg-white/45 p-6 backdrop-blur-sm dark:border-white/15 dark:bg-black/10 md:p-7">
				<div class="mb-3 flex items-center justify-between">
					<h2 class="text-base font-semibold text-black dark:text-white">学生就业能力画像</h2>
					<span class="rounded-full bg-[var(--btn-regular-bg)] px-2 py-0.5 text-xs text-75">八维示意</span>
				</div>
				<p class="mb-4 text-xs leading-relaxed text-75">
					示意图基于能力画像模块口径：理论、交叉、实践、数字、创新、协作、社会、成长。
				</p>
				<div class="flex justify-center">
					<svg width="260" height="260" viewBox="0 0 240 240" class="max-w-full" aria-hidden="true">
						{
							[0.25, 0.5, 0.75, 1].map((tier) => (
								<polygon
									points={radarAxes
										.map((_, i) => {
											const p = radarPoint(i, 100 * tier);
											return `${p.x},${p.y}`;
										})
										.join(" ")}
									fill="none"
									stroke="currentColor"
									class="text-black/10 dark:text-white/10"
									stroke-width="1"
								/>
							))
						}
						{
							radarAxes.map((axis, i) => {
								const linePoint = radarPoint(i, 100);
								const labelPoint = radarPoint(i, 110);
								return (
									<>
										<line
											x1={radarCx}
											y1={radarCy}
											x2={linePoint.x}
											y2={linePoint.y}
											stroke="currentColor"
											class="text-black/15 dark:text-white/15"
											stroke-width="1"
										/>
										<text
											x={labelPoint.x}
											y={labelPoint.y}
											text-anchor="middle"
											dominant-baseline="middle"
											class="fill-black/60 text-[9px] dark:fill-white/70"
										>
											{axis.label}
										</text>
									</>
								);
							})
						}
						<polygon
							points={radarPolygonPoints}
							fill="color-mix(in oklch, var(--primary) 35%, transparent)"
							stroke="var(--primary)"
							stroke-width="2"
						/>
					</svg>
				</div>
			</article>
		</div>
	</div>

	<!-- suillilab MainGridLayout：横幅底水波，填充与页面背景一致，过渡到下方内容区 -->
	<div
		class="home-hero-waves pointer-events-none absolute -bottom-px left-0 right-0 z-[2] h-[10vh] max-h-[9.375rem] min-h-[3.125rem] w-full md:h-[15vh]"
		aria-hidden="true"
	>
		<svg
			class="h-full w-full"
			xmlns="http://www.w3.org/2000/svg"
			xmlns:xlink="http://www.w3.org/1999/xlink"
			viewBox="0 20 150 32"
			preserveAspectRatio="none"
			shape-rendering="auto"
			style="transform: translateZ(0); backface-visibility: hidden;"
		>
			<defs>
				<path
					id="gentle-wave"
					d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v48h-352z"
				>
				</path>
			</defs>
			<g class="parallax" style="transform: translateZ(0);">
				<use
					xlink:href="#gentle-wave"
					href="#gentle-wave"
					x="48"
					y="0"
					class="fill-[var(--page-bg)] opacity-25"
					style="animation-delay: -2s; animation-duration: 7s; will-change: transform;"
				></use>
				<use
					xlink:href="#gentle-wave"
					href="#gentle-wave"
					x="48"
					y="3"
					class="fill-[var(--page-bg)] opacity-50"
					style="animation-delay: -3s; animation-duration: 10s; will-change: transform;"
				></use>
				<use
					xlink:href="#gentle-wave"
					href="#gentle-wave"
					x="48"
					y="5"
					class="fill-[var(--page-bg)] opacity-75"
					style="animation-delay: -4s; animation-duration: 13s; will-change: transform;"
				></use>
				<use
					xlink:href="#gentle-wave"
					href="#gentle-wave"
					x="48"
					y="7"
					class="fill-[var(--page-bg)]"
					style="animation-delay: -5s; animation-duration: 20s; will-change: transform;"
				></use>
			</g>
		</svg>
	</div>
</section>
