---
import { Icon } from "astro-icon/components";

const steps = [
	{
		n: "01",
		title: "录入",
		desc: "简历或表单",
		icon: "material-symbols:edit-document-outline",
	},
	{
		n: "02",
		title: "画像",
		desc: "能力拆解评分",
		icon: "material-symbols:account-tree-outline",
	},
	{
		n: "03",
		title: "匹配",
		desc: "四维度加权",
		icon: "material-symbols:compare-arrows",
	},
	{
		n: "04",
		title: "报告",
		desc: "路径与导出",
		icon: "material-symbols:description-outline",
	},
];
---

<div class="mb-10">
	<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
		<div>
			<h2 class="text-lg font-bold text-black dark:text-white">使用流程</h2>
			<p class="mt-1 text-sm text-75">从画像采集到路径输出，4 步完成可执行的职业规划闭环。</p>
		</div>
		<div class="flex flex-wrap gap-2 text-xs">
			<span class="rounded-full bg-[var(--btn-regular-bg)] px-2.5 py-1 text-75">八维能力画像</span>
			<span class="rounded-full bg-[var(--btn-regular-bg)] px-2.5 py-1 text-75">四维匹配评分</span>
			<span class="rounded-full bg-[var(--btn-regular-bg)] px-2.5 py-1 text-75">可导出行动计划</span>
		</div>
	</div>

	<div class="mb-4 grid gap-3 sm:grid-cols-3">
		<div class="rounded-xl border border-black/8 bg-[var(--card-bg)] p-4 dark:border-white/10">
			<p class="text-xs text-75">画像维度</p>
			<p class="mt-1 text-xl font-bold text-black dark:text-white">8 维</p>
		</div>
		<div class="rounded-xl border border-black/8 bg-[var(--card-bg)] p-4 dark:border-white/10">
			<p class="text-xs text-75">匹配因子</p>
			<p class="mt-1 text-xl font-bold text-black dark:text-white">4 维加权</p>
		</div>
		<div class="rounded-xl border border-black/8 bg-[var(--card-bg)] p-4 dark:border-white/10">
			<p class="text-xs text-75">输出结果</p>
			<p class="mt-1 text-xl font-bold text-black dark:text-white">建议路径 + 报告</p>
		</div>
	</div>

	<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" role="list" aria-label="职业规划流程">
		{
			steps.map((s, i) => (
				<div
					role="listitem"
					class="group relative overflow-hidden rounded-xl border border-black/8 bg-[var(--card-bg)] p-5 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--primary)]/35 hover:shadow-lg hover:shadow-[var(--primary)]/10 dark:border-white/10"
				>
					<div class="mb-3 flex items-center justify-between">
						<span class="font-mono text-xs font-bold text-[var(--primary)]/80">
							{s.n}
						</span>
						<div class="rounded-lg bg-[var(--btn-regular-bg)] p-2 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
							<Icon name={s.icon} class="text-2xl text-[var(--primary)]" />
						</div>
					</div>
					<h3 class="mb-1 font-semibold text-black dark:text-white">{s.title}</h3>
					<p class="text-sm text-75">{s.desc}</p>
					{i < steps.length - 1 && (
						<div
							class="pointer-events-none absolute -right-2 top-1/2 hidden -translate-y-1/2 text-[var(--primary)]/30 lg:block"
							aria-hidden="true"
						>
							<Icon name="material-symbols:chevron-right-rounded" class="text-2xl" />
						</div>
					)}
				</div>
			))
		}
	</div>
</div>
