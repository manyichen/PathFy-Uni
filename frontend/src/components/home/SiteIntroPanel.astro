---
import { Icon } from "astro-icon/components";

const valueCards = [
	{
		title: "看清岗位",
		desc: "把岗位名称背后的能力要求、成长空间和迁移路线拆出来。",
		icon: "material-symbols:work-history-outline",
		tone: "text-cyan-600 dark:text-cyan-300",
	},
	{
		title: "看懂自己",
		desc: "用简历解析和八维画像梳理优势、短板与证据来源。",
		icon: "material-symbols:person-search-outline",
		tone: "text-teal-600 dark:text-teal-300",
	},
	{
		title: "走向行动",
		desc: "把差距诊断转换成学习、项目、实习和复盘计划。",
		icon: "material-symbols:fact-check-outline",
		tone: "text-amber-600 dark:text-amber-300",
	},
];

const steps = [
	"岗位探索",
	"能力画像",
	"人岗匹配",
	"生涯报告",
];
---

<section class="space-y-6" aria-labelledby="intro-title">
	<div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
		<div>
			<p class="text-xs font-semibold uppercase text-[var(--primary)]">Why PathFy-Uni</p>
			<h2
				id="intro-title"
				class="mt-2 max-w-xl text-2xl font-bold leading-snug tracking-normal text-black dark:text-white md:text-3xl"
			>
				不是再做一个信息展示页，而是把职业规划整理成一条工作流。
			</h2>
			<p class="mt-3 max-w-2xl text-sm leading-7 text-75 md:text-base">
				平台围绕“岗位需求”和“个人能力”双侧建模，帮助学生从碎片化信息里抽出真正能指导选择的依据，再落到下一阶段可执行的任务。
			</p>
		</div>

		<div class="grid gap-3 md:grid-cols-3">
			{
				valueCards.map((card) => (
					<article class="rounded-lg border border-black/10 bg-[var(--card-bg)] p-4 shadow-sm shadow-black/5 dark:border-white/10 dark:shadow-none">
						<Icon name={card.icon} class={`text-2xl ${card.tone}`} />
						<h3 class="mt-3 text-base font-semibold tracking-normal text-black dark:text-white">
							{card.title}
						</h3>
						<p class="mt-2 text-sm leading-6 text-75">{card.desc}</p>
					</article>
				))
			}
		</div>
	</div>

	<div class="grid gap-2 md:grid-cols-4">
		{
			steps.map((step, index) => (
				<div class="flex items-center gap-3 rounded-lg bg-[var(--btn-regular-bg)] px-3 py-3">
					<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white text-xs font-bold text-[var(--primary)] shadow-sm shadow-black/5 dark:bg-white/10 dark:shadow-none">
						0{index + 1}
					</span>
					<div>
						<p class="text-sm font-semibold text-black dark:text-white">{step}</p>
						<p class="text-xs text-75">{index === 0 ? "找方向" : index === 1 ? "识别差距" : index === 2 ? "解释匹配" : "制定计划"}</p>
					</div>
				</div>
			))
		}
	</div>
</section>
