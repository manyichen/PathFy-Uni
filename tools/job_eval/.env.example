# 复制为 tools/job_eval/.env；可与 backend/.env 中的 NEO4J_*、DEEPSEEK_API_KEY 保持一致

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

PRIMARY_PROVIDER=deepseek
REVIEW_PROVIDER=qwen
REVIEW_CONFIDENCE_THRESHOLD=0.60
CAP_VERSION=v1.0.0-pilot200

LLM_TIMEOUT_SECONDS=180
JOB_EVAL_WORKERS=3
JOB_EVAL_LIMIT=200
JOB_EVAL_START=1
