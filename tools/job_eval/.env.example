NEO4J_URI=bolt://121.249.156.18:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123456
NEO4J_DATABASE=neo4j

DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# deepseek | qwen
PRIMARY_PROVIDER=deepseek
REVIEW_PROVIDER=qwen

# 低于该置信度触发复核
REVIEW_CONFIDENCE_THRESHOLD=0.50

# 打分版本号，写回图谱使用
CAP_VERSION=v1.0.0-pilot200

# 单次大模型 HTTP 超时（秒）；网络慢或模型排队时可加大
LLM_TIMEOUT_SECONDS=180

# 批量评估并发线程数（1=串行）；可用命令行 --workers 覆盖
JOB_EVAL_WORKERS=3

# 处理条数、从第几条开始（均为 1-based 排序后的 Job 序号）；可用 --limit / --start 覆盖
JOB_EVAL_LIMIT=5
JOB_EVAL_START=1
